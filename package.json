{
  "name": "git-chat-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "concurrently -n web,api \"bun run dev:web\" \"bun run dev:api\"",
    "dev:web": "vite",
    "dev:api": "bun --watch server/index.ts",
    "codex:tasks:list": "bun server/codexThreadTasks.ts list",
    "codex:tasks:attach": "bun server/codexThreadTasks.ts attach",
    "codex:tasks:attach-latest": "bun server/codexThreadTasks.ts attach-latest",
    "codex:tasks:archive": "bun server/codexThreadTasks.ts archive",
    "codex:tasks:bootstrap": "bun server/codexThreadTasks.ts bootstrap",
    "codex:tasks:sync": "bun server/codexThreadTasks.ts sync",
    "codex:tasks:watch": "bun server/codexThreadTasks.ts watch",
    "tauri:dev": "bunx tauri dev",
    "tauri:build": "bunx tauri build",
    "build": "tsgo -b && vite build",
    "test": "bun test",
    "preview": "vite preview",
    "typecheck": "tsgo --noEmit -p tsconfig.app.json && tsgo --noEmit -p tsconfig.node.json",
    "lint": "oxlint src/ server/ test/",
    "lint:fix": "oxlint --fix src/ server/ test/",
    "format": "oxfmt --check src/ server/ test/",
    "format:fix": "oxfmt --write src/ server/ test/",
    "check": "bun run typecheck && bun run lint && bun run format"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.49",
    "@tauri-apps/api": "^2.10.1",
    "ai": "^6.0.143",
    "animejs": "^4.3.6",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/bun": "^1.3.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260330.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
