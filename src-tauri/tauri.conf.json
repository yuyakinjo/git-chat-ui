{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Git Chat UI",
  "version": "0.1.0",
  "identifier": "com.example.git-chat-ui",
  "build": {
    "beforeDevCommand": "bun run dev:web",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Git Chat UI",
        "width": 1480,
        "height": 920,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
